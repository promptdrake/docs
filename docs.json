{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Aisbir Cloud Nusantara",
  "colors": {
    "primary": "#15a393",
    "light": "#06c4c9",
    "dark": "#148078"
  },
  "favicon": "/images/favicon.ico",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Support",
          "icon": "phone",
          "color": {
            "light": "#979696",
            "dark": "#979696"
          },
          "href": "https://portal.aisbirnusantara.com/dashboard/support"
        },
        {
          "anchor": "Home",
          "icon": "newspaper",
          "color": {
            "light": "#a0a0a0",
            "dark": "#a0a0a0"
          },
          "href": "https://portal.aisbirnusantara.com"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Pterodactyl Panel",
            "expanded": true,
            "pages": [
              "pterodactyl/environment",
              "pterodactyl/statuss",
              "pterodactyl/upload-folder",
              "pterodactyl/manage-database",
              "pterodactyl/create-tunnel",
              "pterodactyl/cara-membuat-cronjob",
              "pterodactyl/mengubah-environment-startup",
              "pterodactyl/upgrade-plan"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/logos.svg",
    "dark": "/images/logo-dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@aisbirnusantara.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "instagram": "https://instagram.com/promptdrake"
    }
  },
  "description": "Aisbir Cloud Docs",
  "appearance": {
    "default": "light",
    "strict": true
  },
  "metadata": {
    "timestamp": true
  }
}
